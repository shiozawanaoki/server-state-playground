{
  "name": "server-state-playground",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "pnpm run --parallel dev:vanilla dev:swr dev:tanstack",
    "dev:vanilla": "pnpm --filter playground dev",
    "dev:swr": "pnpm --filter nextjs-swr dev",
    "dev:tanstack": "pnpm --filter tanstack-start dev",
    "build:shared": "pnpm --filter @server-state-playground/shared build"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
